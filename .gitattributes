# Normalize line endings for all files that Git considers text files.
* text=auto eol=lf

# Files and directories below are excluded from `git archive`, which is what
# the Godot Asset Library uses to package downloads. Keeping them here means
# editor users who install via AssetLib only fetch the `addons/` folder.
/.gitattributes export-ignore
/.gitignore     export-ignore
/.github        export-ignore
/LICENSE        export-ignore
/README.md      export-ignore
/icon.png       export-ignore
/project.godot  export-ignore
/export_presets.cfg export-ignore
